# === Database ===
DATABASE_URL=sqlite:///./mealoutpost.db

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === Stripe ===
# Use sk_test_* key from Stripe Dashboard > Test Mode
# Leave empty to skip Stripe calls entirely (stub mode)
STRIPE_SECRET_KEY=
STRIPE_SANDBOX=true

# === Nash ===
# Leave empty to skip Nash calls entirely (log-only mode)
NASH_API_KEY=
NASH_SANDBOX=true

# === LLM Parsing (Gemini preferred, OpenAI fallback) ===
# At least one key enables AI-powered email parsing
GEMINI_API_KEY=
OPENAI_API_KEY=

# === Google Places (address auto-lookup) ===
# Enable the "Find Address" button in the intake form
# Get key from Google Cloud Console > Places API (New)
GOOGLE_PLACES_API_KEY=
