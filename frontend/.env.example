# Frontend environment variables for Meal Outpost
# Copy this file to .env and fill in the values before running locally or deploying.

# Backend API base URL.
# - Local development (default if unset): http://localhost:8000
# - Production: set this to your deployed backend URL, e.g. https://api.mealoutpost.com
VITE_API_BASE=http://localhost:8000

# Backend environment variables (set in backend/.env or your hosting environment)

# Database connection string (AWS RDS PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/mealoutpost

# Allowed frontend origins (comma-separated) — default: localhost dev ports
# CORS_ORIGINS=http://localhost:5173,https://your-app.netlify.app

# Stripe secret key (for future billing integration)
# STRIPE_SECRET_KEY=sk_test_...

# Nash API key (for future delivery dispatch integration)
# NASH_API_KEY=...
